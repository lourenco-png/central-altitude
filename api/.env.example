# Banco de dados PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/central_altitude"

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque-por-64-bytes-aleatorios-em-hex"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
FRONTEND_URL="https://SEU-PROJETO.vercel.app"
API_BASE_URL="https://SEU-PROJETO.onrender.com"

# Cloudinary (armazenamento de arquivos legado — opcional)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
