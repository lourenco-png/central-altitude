generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  password      String
  nome          String
  role          Role                 @default(VIEWER)
  avatar        String?
  ativo         Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  notificacoes  Notificacao[]
  resetTokens   PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique @default(cuid())
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

// ============================================================
// TOPOGRAFIA
// ============================================================

model Obra {
  id           String        @id @default(cuid())
  nome         String
  clienteId    String
  cliente      Cliente       @relation(fields: [clienteId], references: [id])
  status       ObraStatus    @default(ATIVA)
  endereco     String?
  fotos        String[]      @default([])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  solicitacoes Solicitacao[]
  rdos         RDO[]
  medicoes     Medicao[]

  @@index([status])
  @@index([clienteId])
  @@map("obras")
}

model Medicao {
  id        String   @id @default(cuid())
  obraId    String
  obra      Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  descricao String
  valor     Float
  data      DateTime
  status    String   @default("pendente")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("medicoes")
}

enum ObraStatus {
  ATIVA
  PAUSADA
  CONCLUIDA
}

model Engenheiro {
  id           String        @id @default(cuid())
  nome         String
  crea         String?
  telefone     String?
  email        String?
  ativo        Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  solicitacoes Solicitacao[]

  @@map("engenheiros")
}

model Solicitacao {
  id            String            @id @default(cuid())
  obraId        String
  obra          Obra              @relation(fields: [obraId], references: [id])
  engenheiroId  String
  engenheiro    Engenheiro        @relation(fields: [engenheiroId], references: [id])
  data          DateTime
  servico       String?
  descricao     String?
  status        SolicitacaoStatus @default(AGENDADO)
  observacoes   String?
  arquivos      String[]          @default([])
  lembretes     Lembrete[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([data])
  @@index([obraId])
  @@index([engenheiroId])
  @@map("solicitacoes")
}

enum TipoLembrete {
  MEDICAO
  NOTA_FISCAL
}

enum LembreteStatus {
  PENDENTE
  EMITIDO
}

model Lembrete {
  id                String         @id @default(cuid())
  tipo              TipoLembrete
  solicitacaoId     String
  solicitacao       Solicitacao    @relation(fields: [solicitacaoId], references: [id], onDelete: Cascade)
  periodoReferencia String
  status            LembreteStatus @default(PENDENTE)
  dataEmissao       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([tipo, solicitacaoId, periodoReferencia])
  @@index([status])
  @@index([tipo])
  @@index([periodoReferencia])
  @@map("lembretes")
}

enum SolicitacaoStatus {
  AGENDADO
  CONCLUIDO
  CANCELADO
}

model RDO {
  id                String       @id @default(cuid())
  obraId            String
  obra              Obra         @relation(fields: [obraId], references: [id])
  numero            String?
  data              DateTime
  endereco          String?
  responsavel       String?
  turnoManha        Boolean      @default(true)
  turnoTarde        Boolean      @default(true)
  turnoNoite        Boolean      @default(false)
  moi               Json?
  mod               Json?
  equipamentos      Json?
  tarefas           Json?
  ocorrencias       Json?
  obs               String?
  rdoStatus         String       @default("rascunho")
  assinaturaEngNome String?
  assinaturaEngData String?
  // legacy
  clima             String?
  atividades        String?
  observacoes       String?
  fotos             String[]     @default([])
  equipe            Json?
  assinaturas       Assinatura[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([obraId])
  @@index([rdoStatus])
  @@map("rdos")
}

model Assinatura {
  id         String    @id @default(cuid())
  rdoId      String
  rdo        RDO       @relation(fields: [rdoId], references: [id])
  nome       String
  email      String
  assinado   Boolean   @default(false)
  token      String    @unique @default(cuid())
  assinadoEm DateTime?
  createdAt  DateTime  @default(now())

  @@map("assinaturas")
}

// ============================================================
// RH / DP
// ============================================================

model Funcionario {
  id          String            @id @default(cuid())
  nome        String
  cpf         String            @unique
  cargo       String
  setor       String?
  telefone    String?
  email       String?
  admissao    DateTime
  status      FuncionarioStatus @default(ATIVO)
  foto        String?
  documentos          DocumentoFunc[]
  epis                EPI[]
  ferias              Ferias[]
  faltas              Falta[]
  acoesDisciplinares  AcaoDisciplinar[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("funcionarios")
}

enum FuncionarioStatus {
  ATIVO
  AFASTADO
  DEMITIDO
}

model DocumentoFunc {
  id            String      @id @default(cuid())
  funcionarioId String
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])
  nome          String
  arquivo       String?
  emissao       DateTime?
  validade      DateTime?
  createdAt     DateTime    @default(now())

  @@map("documentos_funcionarios")
}

model EPI {
  id            String      @id @default(cuid())
  funcionarioId String
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])
  descricao     String
  ca            String?
  dataEntrega   DateTime?
  validade      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([funcionarioId])
  @@index([validade])
  @@map("epis")
}

model Ferias {
  id            String       @id @default(cuid())
  funcionarioId String
  funcionario   Funcionario  @relation(fields: [funcionarioId], references: [id])
  inicio        DateTime
  fim           DateTime
  dias          Int
  status        FeriasStatus @default(PENDENTE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("ferias")
}

enum FeriasStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

model Falta {
  id            String      @id @default(cuid())
  funcionarioId String
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  data          DateTime
  tipo          TipoFalta   @default(FALTA)
  justificada   Boolean     @default(false)
  motivo        String?
  observacao    String?
  punida        Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("faltas")
}

enum TipoFalta {
  FALTA
  ATRASO
  SAIDA_ANTECIPADA
}

model AcaoDisciplinar {
  id                    String              @id @default(cuid())
  funcionarioId         String
  funcionario           Funcionario         @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  tipo                  TipoAcaoDisciplinar
  data                  DateTime
  motivo                String
  diasSuspensao         Int?
  faltasVinculadas      String[]            @default([])
  documentoPdf          String?
  statusAssinatura      StatusAssinatura    @default(PENDENTE)
  documentoAssinado     String?
  overrideJustificativa String?
  observacao            String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([funcionarioId])
  @@index([tipo])
  @@map("acoes_disciplinares")
}

enum TipoAcaoDisciplinar {
  ADVERTENCIA_VERBAL
  ADVERTENCIA_ESCRITA
  SUSPENSAO
  JUSTA_CAUSA
  CARTA_ABANDONO
}

enum StatusAssinatura {
  PENDENTE
  ASSINADO
  RECUSADO
}

model Empresa {
  id         String             @id @default(cuid())
  nome       String
  cnpj       String             @unique
  endereco   String?
  telefone   String?
  email      String?
  logo       String?
  socios     Socio[]
  documentos DocumentoEmpresa[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@map("empresas")
}

model Socio {
  id         String          @id @default(cuid())
  empresaId  String
  empresa    Empresa         @relation(fields: [empresaId], references: [id])
  nome       String
  cpf        String?
  cargo      String?
  documentos DocumentoSocio[]
  createdAt  DateTime        @default(now())

  @@map("socios")
}

model DocumentoSocio {
  id        String    @id @default(cuid())
  socioId   String
  socio     Socio     @relation(fields: [socioId], references: [id], onDelete: Cascade)
  nome      String
  arquivo   String?
  emissao   DateTime?
  validade  DateTime?
  createdAt DateTime  @default(now())

  @@map("documentos_socios")
}

model DocumentoEmpresa {
  id        String    @id @default(cuid())
  empresaId String
  empresa   Empresa   @relation(fields: [empresaId], references: [id])
  nome      String
  arquivo   String?
  validade  DateTime?
  createdAt DateTime  @default(now())

  @@map("documentos_empresa")
}

// ============================================================
// ARQUIVOS (armazenados no banco, sem dependência externa)
// ============================================================

model File {
  id           String   @id @default(cuid())
  data         Bytes?   // null para arquivos armazenados no R2
  mimetype     String
  originalname String
  size         Int
  storage      String   @default("DB") // "DB" | "R2"
  key          String?  // chave do objeto no R2 (null para arquivos legados no banco)
  createdAt    DateTime @default(now())

  @@map("files")
}

// ============================================================
// COMERCIAL
// ============================================================

model Cliente {
  id           String      @id @default(cuid())
  nome         String
  cnpj         String?     @unique
  email        String?
  telefone     String?
  cidade       String?
  obras        Obra[]
  orcamentos   Orcamento[]
  contratos    Contrato[]
  oportunidades Oportunidade[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("clientes")
}

model Orcamento {
  id               String          @id @default(cuid())
  numero           Int             @default(autoincrement())
  clienteId        String
  cliente          Cliente         @relation(fields: [clienteId], references: [id])
  tipo             TipoOrcamento   @default(GENERICO)
  itens            ItemOrcamento[]
  desconto         Float           @default(0)
  total            Float           @default(0)
  condicoes        String?
  status           OrcamentoStatus @default(RASCUNHO)
  dadosEspecificos   Json?
  aprovacaoToken     String?         @unique
  aprovacaoResposta  String?
  aprovacaoMensagem  String?
  proposta           Proposta?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@map("orcamentos")
}

enum TipoOrcamento {
  GENERICO
  TOPOGRAFIA
  INFRA_PREDIAL
}

enum OrcamentoStatus {
  RASCUNHO
  ENVIADO
  APROVADO
  REJEITADO
}

model ItemOrcamento {
  id          String    @id @default(cuid())
  orcamentoId String
  orcamento   Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  descricao   String
  codigo      String?
  unidade     String?   @default("un")
  quantidade  Float
  unitario    Float
  total       Float
  ordem       Int       @default(0)

  @@map("itens_orcamento")
}

model Proposta {
  id          String         @id @default(cuid())
  orcamentoId String         @unique
  orcamento   Orcamento      @relation(fields: [orcamentoId], references: [id])
  validade    Int            @default(30)
  versao      Int            @default(1)
  observacoes String?
  status      PropostaStatus @default(ENVIADA)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("propostas")
}

enum PropostaStatus {
  ENVIADA
  APROVADA
  REJEITADA
}

model Contrato {
  id        String         @id @default(cuid())
  numero    Int            @default(autoincrement())
  clienteId String
  cliente   Cliente        @relation(fields: [clienteId], references: [id])
  objeto    String
  valor     Float
  inicio    DateTime
  fim       DateTime?
  status    ContratoStatus @default(AGUARDANDO_ASSINATURA)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("contratos")
}

enum ContratoStatus {
  AGUARDANDO_ASSINATURA
  ATIVO
  ENCERRADO
}

model Oportunidade {
  id          String          @id @default(cuid())
  titulo      String
  clienteId   String?
  cliente     Cliente?        @relation(fields: [clienteId], references: [id])
  valor       Float?
  responsavel String?
  estagio     PipelineEstagio @default(LEAD)
  ordem       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("oportunidades")
}

enum PipelineEstagio {
  LEAD
  PROPOSTA
  FECHADO
}

// ============================================================
// NOTIFICAÇÕES
// ============================================================

model Notificacao {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  titulo    String
  mensagem  String
  tipo      String   @default("info")
  lida      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, lida])
  @@index([userId, createdAt])
  @@map("notificacoes")
}
